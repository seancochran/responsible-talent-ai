# Copy to .env and fill in ONE provider. The app works without this
# (deterministic mode); set it to also generate an LLM stakeholder narrative.

# Choose: openai | anthropic | gemini
LLM_PROVIDER=anthropic

# --- Anthropic ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- OpenAI ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini ---
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
